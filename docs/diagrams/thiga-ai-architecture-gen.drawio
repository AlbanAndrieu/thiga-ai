<mxfile host="app.diagrams.net" modified="2026-07-03T00:00:00.000Z" agent="ChatGPT" version="24.7.17" type="device">
  <diagram id="thiga-ai-poc-architecture" name="Thiga AI POC Architecture">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="1050" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="THIGA AI – POC ARCHITECTURE&lt;br&gt;&lt;font style=&#x27;font-size:12px&#x27;&gt;Sovereign AI Platform for HR &amp;amp; Architect Assistants&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontStyle=1;fontSize=18;" vertex="1" parent="1"><mxGeometry x="20" y="20" width="360" height="80" as="geometry"/></mxCell><mxCell id="users" value="Users&lt;br&gt;👤 👤 👤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="620" y="20" width="150" height="60" as="geometry"/></mxCell><mxCell id="cfB" value="NON SOVEREIGN&lt;br&gt;PERIMETER" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#cc0000;dashed=1;dashPattern=6 6;strokeWidth=2;fontColor=#cc0000;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="460" y="90" width="420" height="150" as="geometry"/></mxCell><mxCell id="cf" value="Cloudflare&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Access + Security&lt;/font&gt;&lt;br&gt;&lt;br&gt;• Cloudflare Tunnel&lt;br&gt;• Email Authentication&lt;br&gt;• HTTPS / TLS" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontSize=13;" vertex="1" parent="1"><mxGeometry x="570" y="120" width="210" height="100" as="geometry"/></mxCell><mxCell id="svB" value="SOVEREIGN PERIMETER&lt;br&gt;(IN SCOPE)&lt;br&gt;&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;All data and processing stay inside your infrastructure&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#2e7d32;dashed=1;dashPattern=6 6;strokeWidth=2;fontColor=#2e7d32;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="220" y="250" width="1050" height="590" as="geometry"/></mxCell><mxCell id="l1" value="1. ACCESS LAYER&lt;br&gt;(External)&lt;br&gt;&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Only Open WebUI is accessible from Internet&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f8e9;strokeColor=#2e7d32;fontColor=#1b5e20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="180" width="180" height="110" as="geometry"/></mxCell><mxCell id="l2" value="2. APPLICATION LAYER&lt;br&gt;(Docker Network)&lt;br&gt;&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Core services communicate over private network&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf3ff;strokeColor=#1e5bb8;fontColor=#003c8f;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="400" width="180" height="120" as="geometry"/></mxCell><mxCell id="l3" value="3. DATA &amp;amp; STORAGE LAYER&lt;br&gt;(Internal Services)&lt;br&gt;&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Persistent data, traces, object storage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7e6;strokeColor=#f39c12;fontColor=#b36b00;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="670" width="180" height="110" as="geometry"/></mxCell><mxCell id="l4" value="4. INFRASTRUCTURE LAYER&lt;br&gt;(Host)&lt;br&gt;&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Docker Engine&lt;br&gt;Local VM / Server&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7efff;strokeColor=#8e44ad;fontColor=#6a1b9a;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="860" width="180" height="100" as="geometry"/></mxCell><mxCell id="owui" value="Open WebUI&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;AI Chat Interface &amp;amp; Assistant Hub&lt;/font&gt;&lt;br&gt;Port: 31028 (HTTP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#edf5ff;strokeColor=#1a5cff;strokeWidth=2;fontSize=14;" vertex="1" parent="1"><mxGeometry x="500" y="280" width="320" height="80" as="geometry"/></mxCell><mxCell id="kb" value="Knowledge Base&lt;br&gt;(RAG) – Open WebUI&lt;br&gt;&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Documents (PDF, DOCX, ...)&lt;br&gt;Job Descriptions, CVs&lt;br&gt;Internal Policies&lt;br&gt;&lt;hr&gt;Ingestion via Open WebUI&lt;br&gt;→ Parsing / Chunking&lt;br&gt;→ Embedding Generation&lt;br&gt;→ Storage metadata&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#edf5ff;strokeColor=#1a5cff;strokeWidth=2;fontSize=14;" vertex="1" parent="1"><mxGeometry x="250" y="360" width="200" height="220" as="geometry"/></mxCell><mxCell id="litellm" value="LiteLLM Gateway&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Model Routing, Guardrails,&lt;br&gt;Rate Limiting, Observability&lt;/font&gt;&lt;br&gt;Port: 4000 (HTTP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5edff;strokeColor=#8e44ad;strokeWidth=2;fontSize=14;" vertex="1" parent="1"><mxGeometry x="500" y="430" width="300" height="105" as="geometry"/></mxCell><mxCell id="ollama" value="Ollama&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Local LLM Inference (Sovereign)&lt;/font&gt;&lt;br&gt;Port: 11434 (HTTP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef8e8;strokeColor=#6aa84f;strokeWidth=2;fontSize=14;" vertex="1" parent="1"><mxGeometry x="540" y="585" width="260" height="80" as="geometry"/></mxCell><mxCell id="lf" value="Langfuse&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Observability, Tracing,&lt;br&gt;Sessions, Evaluations&lt;/font&gt;&lt;br&gt;Port: 3000 (HTTP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f2;strokeColor=#d65c72;strokeWidth=2;fontSize=14;" vertex="1" parent="1"><mxGeometry x="970" y="430" width="250" height="105" as="geometry"/></mxCell><mxCell id="pg" value="PostgreSQL&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Application DB&lt;br&gt;(Open WebUI, Langfuse)&lt;/font&gt;&lt;br&gt;&lt;br&gt;Port: 5432 (TCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f39c12;strokeWidth=2;fontSize=13;" vertex="1" parent="1"><mxGeometry x="290" y="705" width="210" height="120" as="geometry"/></mxCell><mxCell id="redis" value="Redis&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Cache, Sessions,&lt;br&gt;Queues (Langfuse)&lt;/font&gt;&lt;br&gt;&lt;br&gt;Port: 6379 (TCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f39c12;strokeWidth=2;fontSize=13;" vertex="1" parent="1"><mxGeometry x="570" y="705" width="210" height="120" as="geometry"/></mxCell><mxCell id="ch" value="ClickHouse&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Traces, Events, Analytics&lt;br&gt;(Langfuse)&lt;/font&gt;&lt;br&gt;&lt;br&gt;Port: 8123 (HTTP)&lt;br&gt;9000 (TCP Native)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f39c12;strokeWidth=2;fontSize=13;" vertex="1" parent="1"><mxGeometry x="835" y="705" width="210" height="120" as="geometry"/></mxCell><mxCell id="minio" value="MinIO (S3)&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Object Storage&lt;br&gt;(Traces, Files, Backups)&lt;/font&gt;&lt;br&gt;&lt;br&gt;Port: 9000 (S3 API)&lt;br&gt;9090 (Console)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f39c12;strokeWidth=2;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1100" y="705" width="210" height="120" as="geometry"/></mxCell><mxCell id="docker" value="Docker Engine&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;All services run as isolated containers&lt;br&gt;Docker Network (bridge)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#777777;strokeWidth=2;fontSize=14;" vertex="1" parent="1"><mxGeometry x="360" y="875" width="450" height="85" as="geometry"/></mxCell><mxCell id="server" value="Local VM / Server&lt;br&gt;&lt;font style=&#x27;font-size:11px&#x27;&gt;Linux (x86_64)&lt;br&gt;With GPU recommended&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#777777;strokeWidth=2;fontSize=14;" vertex="1" parent="1"><mxGeometry x="870" y="875" width="280" height="85" as="geometry"/></mxCell><mxCell id="exposed" value="EXPOSED PORTS (From Host)&lt;br&gt;&lt;br&gt;🟢 31028 → Open WebUI&lt;br&gt;🔴 3000 → Langfuse UI (Admin)&lt;br&gt;🟠 9090 → MinIO Console (Admin)&lt;br&gt;🟠 8123 → ClickHouse (Optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1300" y="110" width="260" height="195" as="geometry"/></mxCell><mxCell id="internal" value="INTERNAL PORTS (Docker Network)&lt;br&gt;&lt;br&gt;🔵 NOT exposed to host / Internet&lt;br&gt;• LiteLLM : 4000&lt;br&gt;• Ollama : 11434&lt;br&gt;• PostgreSQL : 5432&lt;br&gt;• Redis : 6379&lt;br&gt;• ClickHouse Native : 9000&lt;br&gt;• MinIO S3 API : 9000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1300" y="320" width="260" height="215" as="geometry"/></mxCell><mxCell id="protocols" value="PROTOCOLS&lt;br&gt;&lt;br&gt;━━ HTTP (not encrypted)&lt;br&gt;- - - Internal Docker Network&lt;br&gt;╌╌ TCP (Database / Internal)&lt;br&gt;━━ HTTPS (Cloudflare only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1300" y="555" width="260" height="170" as="geometry"/></mxCell><mxCell id="notes" value="NOTES&lt;br&gt;&lt;br&gt;• All data stays inside infrastructure&lt;br&gt;• Only Open WebUI is accessible to end users&lt;br&gt;• Observability via Langfuse&lt;br&gt;• LiteLLM centralizes routing, guardrails, logs&lt;br&gt;• Cloudflare is outside sovereign perimeter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1300" y="740" width="260" height="185" as="geometry"/></mxCell><mxCell id="e1" value="HTTPS" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="users" target="cf"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="HTTP" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="cf" target="owui"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="OpenAI compatible API&lt;br&gt;(HTTP)" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="owui" target="litellm"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="Ollama API&lt;br&gt;(HTTP)" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="litellm" target="ollama"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="Observability / Traces&lt;br&gt;(HTTP)" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="litellm" target="lf"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" value="RAG ingestion / retrieval" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="owui" target="kb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" value="TCP&lt;br&gt;PostgreSQL Protocol" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;dashPattern=4 4;" edge="1" parent="1" source="litellm" target="pg"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e8" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;dashPattern=4 4;" edge="1" parent="1" source="lf" target="redis"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e9" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;dashPattern=4 4;" edge="1" parent="1" source="lf" target="ch"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e10" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;dashPattern=4 4;" edge="1" parent="1" source="lf" target="minio"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e11" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="server" target="docker"><mxGeometry relative="1" as="geometry"/></mxCell></root>
    </mxGraphModel>
